{
  "$schema": "https://schemas.helloprint.com/brand-tokens/v1.json",
  "meta": {
    "name": "HelloPrint Brand Tokens",
    "version": "0.1.0",
    "source": "Brand DNA + Tone of Voice — April 2026",
    "owner": "brand@helloprint.com",
    "status": "canonical",
    "convention": "kebab-case. Categories: color, font, space, radius. Access as dot-path, e.g. color.brand.charmed-green."
  },

  "brand": {
    "name": "HelloPrint",
    "legal-name": "Helloprint B.V.",
    "capitalization": "HelloPrint",
    "forbidden-forms": ["Helloprint", "helloprint", "HELLOPRINT", "Hello Print", "Hello-Print"],
    "tagline": "We make print easy."
  },

  "color": {
    "brand": {
      "charmed-green": { "hex": "#008539", "use": "Primary brand colour — logo, buttons, key accents (must appear on every ad asset)" },
      "link-green":    { "hex": "#049E46", "use": "Interactive elements, links, hover states" },
      "thamar-black":  { "hex": "#022B07", "use": "Deep green-black for full dark panels and dark sections" },
      "snowflake":     { "hex": "#F0F0F0", "use": "Page backgrounds, cards, secondary surfaces" },
      "orochimaru":    { "hex": "#D9D9D9", "use": "Light backgrounds, dividers, subtle UI surfaces" }
    },
    "accent": {
      "heroic-red":     { "hex": "#D64545", "use": "Urgency, alerts, energy accents — use sparingly" },
      "honey-teriyaki": { "hex": "#F36D13", "use": "Warmth, warnings, call-to-attention accents" },
      "ripe-mango":     { "hex": "#FDC225", "use": "Highlights, promos, optimism accents" },
      "hampton-beach":  { "hex": "#9D6639", "use": "Earth tone for craft and material contexts" },
      "seaside":        { "hex": "#67A5B1", "use": "Calm, trust, informational accents" },
      "rule":           "Max one accent colour per asset. Never combine accents."
    },
    "neutral": {
      "digital-black": { "hex": "#191919", "use": "Replaces pure black on screens" },
      "digital-white": { "hex": "#FFFFFF", "use": "Pure white on screens" }
    },
    "hierarchy": {
      "rule": "60 / 30 / 10",
      "dominant":   { "share": 60, "role": "Background — white, snowflake, or thamar black" },
      "supporting": { "share": 30, "role": "Text and structure — digital black or white" },
      "accent":     { "share": 10, "role": "Charmed Green primary (>=7%) + optional secondary accent (<=3%)" }
    },
    "background": {
      "full-dark-green":    { "hex": "#022B07", "use": "Primary dark panel — B2B, high-impact, promotional" },
      "split-white-strip":  { "description": "White body with Thamar Black strip (header or footer)", "use": "Product / seasonal" },
      "full-light":         { "hex": "#FFFFFF", "use": "Primary light canvas — lifestyle, soft tone, logo-led" },
      "full-charmed-green": { "hex": "#008539", "use": "Billboards / OOH only — never for long-read UI" }
    }
  },

  "font": {
    "family": {
      "primary":     { "name": "Inter",  "license": "SIL Open Font License 1.1", "source": "https://fonts.google.com/specimen/Inter" },
      "handwritten": { "name": "Smiley", "license": "Proprietary (brand-only)",   "use": "Greetings and sign-offs only — never prices, guarantees, legal, or body copy" }
    },
    "weight": {
      "bold":      { "value": 700, "use": "H1, H2 — headlines" },
      "semi-bold": { "value": 600, "use": "H3, H4, labels — sub-headlines" },
      "regular":   { "value": 400, "use": "Body, body-small" }
    },
    "scale": {
      "desktop": {
        "h1":         { "weight": 700, "size": "32px", "line-height": "40px" },
        "h2":         { "weight": 700, "size": "24px", "line-height": "32px" },
        "h3":         { "weight": 600, "size": "16px", "line-height": "24px" },
        "h4":         { "weight": 600, "size": "14px", "line-height": "22px" },
        "body":       { "weight": 400, "size": "14px", "line-height": "22px" },
        "body-small": { "weight": 400, "size": "12px", "line-height": "20px" },
        "label":      { "weight": 600, "size": "10px", "line-height": "14px", "case": "uppercase", "letter-spacing": "0.04em" }
      },
      "mobile": {
        "h1":         { "weight": 700, "size": "24px", "line-height": "30px" },
        "h2":         { "weight": 700, "size": "18px", "line-height": "24px" },
        "h3":         { "weight": 600, "size": "14px", "line-height": "20px" },
        "h4":         { "weight": 600, "size": "12px", "line-height": "16px" },
        "body":       { "weight": 400, "size": "12px", "line-height": "16px" },
        "body-small": { "weight": 400, "size": "10px", "line-height": "14px" },
        "label":      { "weight": 600, "size": "10px", "line-height": "14px", "case": "uppercase" }
      }
    }
  },

  "space": {
    "base": "4px",
    "xxs":  "2px",
    "xs":   "4px",
    "sm":   "8px",
    "md":   "16px",
    "lg":   "24px",
    "xl":   "32px",
    "2xl":  "48px",
    "3xl":  "64px"
  },

  "radius": {
    "sm":   "4px",
    "md":   "8px",
    "lg":   "16px",
    "full": "9999px"
  },

  "logo": {
    "kind": "wordmark",
    "file": {
      "wordmark-on-dark":  { "path": "assets/logos/helloprint-wordmark-white.svg", "use": "On dark green, thamar black, or dark-image backgrounds" },
      "wordmark-on-light": { "path": "assets/logos/helloprint-wordmark-black.svg", "use": "On white, snowflake, or light-image backgrounds" },
      "monogram-accent":   { "path": "assets/logos/helloprint-monogram-green.svg", "use": "App icons, favicons, small-scale brand marks — default monogram" },
      "monogram-on-light": { "path": "assets/logos/helloprint-monogram-white.svg", "use": "App icons, favicons on light surfaces (white circle, dark H)" },
      "monogram-on-dark":  { "path": "assets/logos/helloprint-monogram-dark.svg",  "use": "App icons, favicons on dark surfaces where green is not appropriate" }
    },
    "clear-space": "Equal to the height of the capital H in the wordmark on all sides",
    "min-size": {
      "wordmark": { "digital": "120px wide", "print": "25mm wide" },
      "monogram": { "digital": "24px",       "print": "8mm" }
    },
    "missing-assets": [
      "Wordmark on HelloPrint Green background — awaiting brand team delivery"
    ]
  },

  "voice": {
    "words":   ["Friendly", "Pragmatic", "Expert"],
    "default": ["Friendly", "Expert", "Human"],
    "character": "A friend who happens to know everything about print — grounded, warm, assured, measured. Male, 28–38, clear and accessible register.",
    "by-context": {
      "transactional": ["Clear", "Calm", "Structured"],
      "marketing":     ["Playful", "Confident", "Helpful"],
      "support":       ["Warm", "Direct", "Solution-first"],
      "ooh":           ["Bold", "Short", "ALL CAPS (3–4 words max)"],
      "internal":      ["Candid", "Concise", "Respectful"]
    }
  }
}
